{
  "name": "cosmetic-store",
  "version": "1.0.0",
  "description": "Cosmetic e-commerce store for Cypress practice",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --testPathPatterns=unit",
    "test:integration": "jest --testPathPatterns=integration",
    "test:bdd": "npx cucumber-js tests/bdd/features --require tests/bdd/features/step_definitions/**/*.js",
    "test:e2e": "npx playwright test",
    "test:coverage": "jest --coverage --testPathPatterns=\"(unit|integration)\" --runInBand",
    "test:watch": "jest --watch",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:bdd && npm run test:e2e"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mysql2": "^3.6.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.3",
    "@playwright/test": "^1.59.1",
    "http-server": "^14.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "nyc": "^18.0.0",
    "supertest": "^7.2.2"
  },
  "nyc": {
    "all": true,
    "reporter": [
      "lcov",
      "text"
    ],
    "include": [
      "server.js",
      "public/app.js",
      "utils/**/*.js"
    ],
    "exclude": [
      "**/tests/**",
      "**/node_modules/**"
    ],
    "check-coverage": true,
    "lines": 80,
    "functions": 80,
    "branches": 80,
    "statements": 80
  }
}
